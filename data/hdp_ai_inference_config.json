  "retrieval_strategy": {
    "order_of_operations": [
      "Classify the user question into the closest supported question_class.",
      "Extract meaningful question terms and concept synonyms.",
      "Retrieve directly relevant professional evidence from the configured core entities first.",
      "Apply entity quotas so the evidence pack includes multiple evidence types instead of one repeated theme.",
      "Retrieve matching derived_signal rows from the behavioral dataset by behavioral_priority_dimensions.",
      "Use cross_source_alignment and question relevance to rank behavioral signals.",
      "Assemble the response while explicitly separating observed evidence from behavioral interpretation."
    ],
    "retrieval_limits": {
      "max_behavioral_signals_before_synthesis": 4,
      "max_core_records_before_synthesis": 8,
      "max_signal_evidence_links_per_signal": 2,
      "prefer_recent_or_higher_weighted_sources_when_tied": true
    },
    "concept_synonyms": {
      "summary": ["overview", "what do you know", "tell me about anthony", "who is anthony"],
      "strength": ["strengths", "strongest", "differentiator", "advantage"],
      "value": ["impact", "outcome", "contribution", "value creation"],
      "technical": ["architecture", "platform", "data", "analytics", "integration"],
      "fit": ["alignment", "suited", "best suited", "match"],
      "work style": ["communication", "decision", "collaboration", "ambiguity"],
      "risk": ["blind spot", "friction", "stress", "overdo"]
    }
  },
  "answer_contract": {
    "evidence_labeling_rules": [
      "Label observed professional evidence separately from behavioral signals when both are used.",
      "If a point is supported mainly by self-reported or assessment-derived evidence, say so.",
      "If multiple behavioral artifacts reinforce a signal, describe it as cross-source reinforcement.",
      "If sources disagree or support is weak, state that clearly instead of smoothing it over."
    ],
    "optional_sections_when_needed": [
      "behavioral_reinforcement",
      "caution_or_limitation",
      "deeper_hdp_redirect"
    ],
    "required_sections_by_default": [
      "direct_answer",
      "differentiated_observations",
      "supporting_evidence"
    ],
    "style_rules": [
      "Respond in third person when describing Anthony.",
      "Do not write as if the system is Anthony.",
      "Do not present assessment labels as definitive truth.",
      "Prefer concise evidence-backed statements over personality language.",
      "Use explicit uncertainty language when support is partial, weak, or mostly self-reported."
    ],
    "response_composition_rules": [
      "Answer the question directly before summarizing patterns.",
      "Use at least two different evidence types when the data supports it.",
      "Prefer raw structured evidence over portfolio-level summaries.",
      "Do not cite the HDP itself or the Capability Model as primary proof when underlying data exists."
    ],
    "overused_themes_to_avoid": [
      "reduces ambiguity",
      "simplifies complexity",
      "brings structure",
      "clarity"
    ]
  },
  "confidence_and_limitation_rules": {
    "confidence_language": {
      "high": "strong evidence suggests",
      "medium": "available evidence suggests",
      "low": "there are some indications, but support is limited"
    },
    "limitation_triggers": [
      "behavioral support is from a single low-confidence artifact only",
      "signal confidence falls below direct-claim threshold",
      "observed professional evidence does not reinforce the behavioral signal",
      "question asks for certainty beyond what the data supports"
    ],
    "limitation_behavior": [
      "downgrade certainty",
      "name the limitation explicitly",
      "avoid absolute or diagnostic phrasing"
    ]
  },
  "cross_domain_response_rules": {
    "when_to_blend_domains": [
      "role fit questions",
      "how Anthony works questions",
      "environment fit questions",
      "questions about alignment between self-perception and observed work"
    ],
    "when_to_prefer_core_dataset_only": [
      "project history",
      "experience chronology",
      "skills inventory",
      "specific system improvement examples"
    ],
    "when_to_prefer_behavioral_dataset_only": [
      "communication tendencies",
      "decision style",
      "conflict approach",
      "behavioral blind spots",
      "assessment pattern questions"
    ]
  },
  "behavioral_usage_rules": {
    "default_mode": "reinforcing",
    "behavioral_lead_question_classes": [
      "work_style",
      "environment_fit",
      "blind_spots_or_risks"
    ],
    "max_behavioral_signals_if_core_evidence_present": 2,
    "prefer_behavioral_signals_with_cross_source_alignment": true,
    "deprioritize_behavioral_signals_when_core_evidence_already_supports_same_theme": true
  },
  "supported_ui_behaviors": {
    "allow_follow_up_prompt_suggestions": true,
    "allow_deeper_hdp_redirects": true,
    "deeper_hdp_redirect_targets": [
